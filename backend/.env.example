# MiniMax-M3 (OpenAI 兼容格式，开发阶段)
# 申请：https://api.minimax.chat/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M3

# 小米 MiMo v2.5 (OpenAI 兼容格式)
# 申请：https://xiaomimimo.com/
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5

# LLM 选择: "minimax" / "spark" / "mimo"
# 比赛当天务必改成 "spark"，并填入讯飞星火 KEY
LLM_PROVIDER=mimo

# 讯飞星火 V4 (比赛必用)
# 申请：https://xinghuo.xfyun.cn/
SPARK_API_KEY=your_spark_api_key_here
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1
SPARK_CHAT_MODEL=generalv3.5
SPARK_EMBEDDING_MODEL=text

# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/zhishu
REDIS_URL=redis://localhost:6379/0

# MinIO（可选，文件存储）
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin